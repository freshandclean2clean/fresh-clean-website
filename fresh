<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Fresh & Clean Home Improvement LLC</title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0f0f0f;
      color: #ffffff;
      line-height: 1.6;
    }
    .container {
      width: 90%;
      max-width: 1100px;
      margin: 0 auto;
    }
    header {
      background: linear-gradient(135deg, #111111, #1b1b1b);
      border-bottom: 2px solid #d4af37;
      padding: 60px 0;
      text-align: center;
    }
    h1, h2, h3 {
      margin-top: 0;
      color: #d4af37;
    }
    .tagline {
      font-size: 1.3rem;
      margin: 10px 0 20px;
      color: #f5f5f5;
    }
    .domain {
      font-size: 1rem;
      margin-bottom: 24px;
      color: #d4af37;
      font-weight: bold;
    }
    .button-row {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 25px;
    }
    .btn {
      display: inline-block;
      padding: 14px 22px;
      background: #d4af37;
      color: #111111;
      text-decoration: none;
      border-radius: 10px;
      font-weight: bold;
    }
    .btn.alt {
      background: transparent;
      color: #ffffff;
      border: 1px solid #d4af37;
    }
    section {
      padding: 50px 0;
      border-bottom: 1px solid rgba(212, 175, 55, 0.2);
    }
    .grid {
      display: grid;
      gap: 20px;
    }
    .services, .plans {
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    }
    .card {
      background: #1a1a1a;
      border: 1px solid rgba(212, 175, 55, 0.25);
      border-radius: 16px;
      padding: 22px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    }
    ul { padding-left: 20px; }
    .price {
      font-size: 1.8rem;
      font-weight: bold;
      color: #ffffff;
      margin: 12px 0;
    }
    .popular {
      display: inline-block;
      background: #d4af37;
      color: #111111;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 0.8rem;
      font-weight: bold;
      margin-bottom: 10px;
    }
    footer {
      text-align: center;
      padding: 30px 0 50px;
      color: #cccccc;
    }
    .contact-box {
      text-align: center;
      background: #171717;
      border: 1px solid rgba(212, 175, 55, 0.25);
      border-radius: 16px;
      padding: 28px;
    }
    @media (max-width: 640px) {
      header { padding: 40px 0; }
      .tagline { font-size: 1.1rem; }
    }
  </style>
</head>
